#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# If running the Rails server then create or migrate the SQLite databases.
if [[ " $* " == *" ./bin/rails server "* ]] || [[ " $* " == *" bin/rails server "* ]] || [[ " $* " == *" rails server "* ]]; then
  ./bin/rails db:prepare
fi

exec "${@}"
